@page "/cs2"
<PageTitle>E-sportowe mecze - CS2</PageTitle>

<section class="hero">
    <div class="hero-content">
        <span class="game-badge">
            <img src="images/games/cs2.png" alt="CS2" class="game-badge-logo" />
            Counter-Strike 2
        </span>
        <h2 style="margin-top: 15px;">Mecze CS2</h2>
        <p>Najlepsze rozgrywki taktycznego shootera</p>
    </div>
</section>

<CountdownTimer Matches="Matches" />

<main class="container">
    <h2 class="section-title">Mecze CS2</h2>
    <div class="matches-grid">
        @foreach (var match in Matches)
        {
            <MatchCard Match="match" />
        }
    </div>
</main>

