@page "/lol"
<PageTitle>E-sportowe mecze - League of Legends</PageTitle>

<section class="hero">
    <div class="hero-content">
        <span class="game-badge">
            <img src="images/games/lol.png" alt="LoL" class="game-badge-logo" />
            League of Legends
        </span>
        <h2 style="margin-top: 15px;">Mecze LoL</h2>
        <p>Najlepsze pojedynki na Summoner's Rift</p>
    </div>
</section>

<CountdownTimer Matches="Matches" />

<main class="container">
    <h2 class="section-title">Mecze League of Legends</h2>
    <div class="matches-grid">
        @foreach (var match in Matches)
        {
            <MatchCard Match="match" />
        }
    </div>
</main>

