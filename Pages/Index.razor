@page "/"
<PageTitle>E-sportowe mecze - Strona główna</PageTitle>

<section class="hero">
    <div class="hero-content">
        <h2>Witaj w świecie e-sportu!</h2>
        <p>Wybierz grę, aby zobaczyć nadchodzące mecze</p>
    </div>
</section>

<main class="container">
    <h2 class="section-title">Wybierz grę</h2>

    <div class="games-grid">
        <a href="/cs2" class="game-card">
            <div class="game-card-header cs2-bg">
                <img src="images/games/cs2.png" alt="CS2 logo" class="game-card-logo" />
                CS2
            </div>
            <div class="game-card-body">
                <p>Counter-Strike 2 - klasyczny shooter taktyczny</p>
                <span class="game-card-link">Zobacz mecze →</span>
            </div>
        </a>

        <a href="/dota2" class="game-card">
            <div class="game-card-header dota2-bg">
                <img src="images/games/dota2.png" alt="Dota 2 logo" class="game-card-logo" />
                Dota 2
            </div>
            <div class="game-card-body">
                <p>Najbardziej kompleksowa gra MOBA</p>
                <span class="game-card-link">Zobacz mecze →</span>
            </div>
        </a>

        <a href="/lol" class="game-card">
            <div class="game-card-header lol-bg">
                <img src="images/games/lol.png" alt="LoL logo" class="game-card-logo" />
                League of Legends
            </div>
            <div class="game-card-body">
                <p>Najpopularniejsza MOBA na świecie</p>
                <span class="game-card-link">Zobacz mecze →</span>
            </div>
        </a>

        <a href="/valorant" class="game-card">
            <div class="game-card-header valorant-bg">
                <img src="images/games/valorant.png" alt="Valorant logo" class="game-card-logo" />
                Valorant
            </div>
            <div class="game-card-body">
                <p>Taktyczny shooter od Riot Games</p>
                <span class="game-card-link">Zobacz mecze →</span>
            </div>
        </a>
    </div>
</main>