@page "/dota2"
<PageTitle>E-sportowe mecze - Dota 2</PageTitle>

<section class="hero">
    <div class="hero-content">
        <span class="game-badge">
            <img src="images/games/dota2.png" alt="Dota 2" class="game-badge-logo" />
            Dota 2
        </span>
        <h2 style="margin-top: 15px;">Mecze Dota 2</h2>
        <p>Epickie bitwy 5v5 w Dire i Radiant</p>
    </div>
</section>

<CountdownTimer Matches="Matches" />

<main class="container">
    <h2 class="section-title">Mecze Dota 2</h2>
    <div class="matches-grid">
        @foreach (var match in Matches)
        {
            <MatchCard Match="match" />
        }
    </div>
</main>

