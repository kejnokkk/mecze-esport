@page "/valorant"
<PageTitle>E-sportowe mecze - Valorant</PageTitle>

<section class="hero">
    <div class="hero-content">
        <span class="game-badge">
            <img src="images/games/valorant.png" alt="Valorant" class="game-badge-logo" />
            Valorant
        </span>
        <h2 style="margin-top: 15px;">Mecze Valorant</h2>
        <p>Taktyczne starcia agentów od Riot Games</p>
    </div>
</section>

<CountdownTimer Matches="Matches" />

<main class="container">
    <h2 class="section-title">Mecze Valorant</h2>
    <div class="matches-grid">
        @foreach (var match in Matches)
        {
            <MatchCard Match="match" />
        }
    </div>
</main>

